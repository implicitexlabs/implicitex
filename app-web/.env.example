# Copy this file to .env and fill in real values locally.
# .env is gitignored — never commit it.
# Placeholder values only in this file.

# Deploy wallet private key (testnet EOA only; never use a mainnet key here)
IMPLICITEX_DEPLOYER_KEY=

# RPC provider URLs (from Alchemy, Infura, QuickNode, etc.)
IMPLICITEX_RPC_URL_AMOY=
IMPLICITEX_RPC_URL_POLYGON=

# Polygonscan API key (for contract verification)
ETHERSCAN_API_KEY=

# Deploy params — read by app-web/scripts/deploy_implicitex_transfer.js
IMPLICITEX_USDC_ADDRESS=
IMPLICITEX_TREASURY_ADDRESS=
IMPLICITEX_INITIAL_FEE_BPS=
IMPLICITEX_MIN_TRANSFER_AMOUNT=
IMPLICITEX_TRANSFER_PRECISION=
